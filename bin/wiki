#!/usr/bin/env bash
# bin/wiki — Wiki CLI 入口
#
# 直接 exec venv python + tools.cli_main, 无后端进程.
# 所有数据/操作都是本地的 (csv / git / md), 不需要 HTTP server.
#
# 安装:
#   ./bootstrap.sh   # 装到 ~/.local/bin/wiki
#
# Windows 用户: 用 bin\wiki.cmd (cmd/PowerShell) 或 bin\wiki.ps1 (PowerShell)

set -euo pipefail

# 找 repo root (此脚本所在目录的上一级, 解析 symlink)
# 用 cd/pwd 而不是 readlink -f: Git Bash on Windows 没装 coreutils 时 readlink -f 失败
if command -v readlink >/dev/null 2>&1 && readlink -f / >/dev/null 2>&1; then
    SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
else
    SCRIPT_PATH="${BASH_SOURCE[0]}"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"

PY="$REPO_ROOT/.venv/bin/python"
if [[ ! -x "$PY" ]]; then
    echo "✗ 找不到 venv python ($PY), 跑 ./bootstrap.sh 装 venv" >&2
    exit 1
fi

cd "$REPO_ROOT"
exec "$PY" -m tools.cli_main "$@"